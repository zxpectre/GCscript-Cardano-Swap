{
    "type": "script",
    "title": "Swap Limit Order",
    "description": "Fills an existing one-way swap UTxO on the Cardano-Swaps protocol via GCscript. Deposits the ask asset and receives the offer asset. Partial fill: remaining offer stays at DApp address with updated datum.",
    "exportAs": "swapLimitOrder",
    "args": {
        "swap-tx-hash": "",
        "swap-tx-index": "",
        "owner-stake-keyhash": "",
        "offer-policy-id": "",
        "offer-asset-name": "",
        "ask-policy-id": "",
        "ask-asset-name": "",
        "price-numerator": "",
        "price-denominator": "",
        "output-ada-quantity": "",
        "remaining-offer-quantity": ""
    },
    "run": {
        "dependencies": {
            "type": "script",
            "args": "{get('args')}",
            "run": {
                "spendingValidator": {
                    "type": "plutusScript",
                    "script": {
                        "scriptHex": "",
                        "lang": "plutus_v2"
                    }
                },
                "pairBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray(get('args.offer-policy-id')), hexToByteArray(get('args.offer-asset-name')), hexToByteArray('00'), hexToByteArray(get('args.ask-asset-name'))))}"
                },
                "offerBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray('01'), hexToByteArray(get('args.offer-policy-id')), hexToByteArray(get('args.offer-asset-name'))))}"
                },
                "askBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray('02'), hexToByteArray(get('args.ask-policy-id')), hexToByteArray(get('args.ask-asset-name'))))}"
                },
                "swapRedeemer": {
                    "type": "plutusData",
                    "data": {
                        "fromJSON": {
                            "schema": 1,
                            "obj": {
                                "constructor": 2,
                                "fields": []
                            }
                        }
                    }
                },
                "outputDatum": {
                    "type": "plutusData",
                    "data": {
                        "fromJSON": {
                            "schema": 1,
                            "obj": {
                                "constructor": 0,
                                "fields": [
                                    {"bytes": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209"},
                                    {"bytes": "{get('cache.dependencies.pairBeacon')}"},
                                    {"bytes": "{get('args.offer-policy-id')}"},
                                    {"bytes": "{get('args.offer-asset-name')}"},
                                    {"bytes": "{get('cache.dependencies.offerBeacon')}"},
                                    {"bytes": "{get('args.ask-policy-id')}"},
                                    {"bytes": "{get('args.ask-asset-name')}"},
                                    {"bytes": "{get('cache.dependencies.askBeacon')}"},
                                    {"constructor": 0, "fields": [
                                        {"int": "{jsonToObj(get('args.price-numerator'))}"},
                                        {"int": "{jsonToObj(get('args.price-denominator'))}"}
                                    ]},
                                    {"constructor": 0, "fields": [
                                        {"constructor": 0, "fields": [
                                            {"constructor": 0, "fields": [
                                                {"bytes": "{get('args.swap-tx-hash')}"}
                                            ]},
                                            {"int": "{jsonToObj(get('args.swap-tx-index'))}"}
                                        ]}
                                    ]},
                                    {"constructor": 1, "fields": []}
                                ]
                            }
                        }
                    }
                },
                "dappAddress": {
                    "type": "buildAddress",
                    "name": "DAppAddress",
                    "addr": {
                        "spendScriptHashHex": "1d6cff26bcab91d2061aad0bd259cbb7d76d25ced2eeaed5926a42ad",
                        "stakePubKeyHashHex": "{get('args.owner-stake-keyhash')}"
                    }
                }
            }
        },
        "build": {
            "type": "buildTx",
            "name": "built-swap",
            "tx": {
                "inputs": [
                    {
                        "txHash": "{get('args.swap-tx-hash')}",
                        "index": "{jsonToObj(get('args.swap-tx-index'))}",
                        "idPattern": "swap-input"
                    }
                ],
                "outputs": [
                    {
                        "address": "{get('cache.dependencies.dappAddress')}",
                        "datum": {
                            "datumHex": "{get('cache.dependencies.outputDatum.dataHex')}"
                        },
                        "assets": [
                            {
                                "policyId": "{get('args.offer-policy-id')}",
                                "assetNameHex": "{get('args.offer-asset-name')}",
                                "quantity": "{get('args.remaining-offer-quantity')}"
                            },
                            {
                                "policyId": "ada",
                                "assetName": "ada",
                                "quantity": "{get('args.output-ada-quantity')}"
                            },
                            {
                                "policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209",
                                "assetNameHex": "{get('cache.dependencies.pairBeacon')}",
                                "quantity": "1"
                            },
                            {
                                "policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209",
                                "assetNameHex": "{get('cache.dependencies.offerBeacon')}",
                                "quantity": "1"
                            },
                            {
                                "policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209",
                                "assetNameHex": "{get('cache.dependencies.askBeacon')}",
                                "quantity": "1"
                            }
                        ]
                    }
                ],
                "witnesses": {
                    "plutus": {
                        "scripts": [
                            {
                                "scriptHex": "{get('cache.dependencies.spendingValidator.scriptHex')}",
                                "lang": "{get('cache.dependencies.spendingValidator.lang')}"
                            }
                        ],
                        "consumers": [
                            {
                                "scriptHashHex": "{get('cache.dependencies.spendingValidator.scriptHashHex')}",
                                "redeemer": {
                                    "dataHex": "{get('cache.dependencies.swapRedeemer.dataHex')}",
                                    "type": "spend",
                                    "itemIdPattern": "swap-input"
                                }
                            }
                        ]
                    }
                },
                "options": {
                    "collateralCoinSelection": "LASLAD"
                }
            }
        },
        "sign": {
            "type": "signTxs",
            "namePattern": "signed-swap",
            "detailedPermissions": false,
            "txs": [
                "{get('cache.build.txHex')}"
            ]
        },
        "submit": {
            "type": "submitTxs",
            "namePattern": "submitted-swap",
            "txs": "{get('cache.sign')}"
        }
    }
}