{
    "type": "script",
    "title": "Open Limit Order",
    "description": "Creates a one-way swap UTxO on the Cardano-Swaps protocol via GCscript.",
    "exportAs": "openLimitOrder",
    "args": {
        "offerPolicyId": "",
        "offerAssetName": "",
        "askPolicyId": "<ask_policy_id_hex>",
        "askAssetName": "<ask_asset_name_hex>",
        "pairBeacon": "<sha2_256(offer_id* ++ offer_name ++ ask_id* ++ ask_name)>",
        "offerBeacon": "<sha2_256(0x01 ++ offer_id ++ offer_name)>",
        "askBeacon": "<sha2_256(0x02 ++ ask_id ++ ask_name)>",
        "priceNumerator": 0,
        "priceDenominator": 0,
        "offerQuantity": "0"
    },
    "run": {
        "dependencies": {
            "type": "script",
            "run": {
                "spendingValidator": {
                    "type": "plutusScript",
                    "script": {
                        "scriptHex": "",
                        "lang": "plutus_v2"
                    }
                },
                "beaconPolicy": {
                    "type": "plutusScript",
                    "script": {
                        "scriptHex": "",
                        "lang": "plutus_v2"
                    },
                    "scriptParams": [
                        {
                            "bytes": "{get('cache.spendingValidator.scriptHashHex')}"
                        }
                    ]
                },
                "stakingKey": {
                    "type": "getStakingPublicKey"
                }
            }
        }
    }
}