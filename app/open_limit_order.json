{
    "type": "script",
    "title": "Open Limit Order",
    "description": "Creates a one-way swap UTxO on the Cardano-Swaps protocol via GCscript.",
    "exportAs": "openLimitOrder",
    "args": {
        "offerPolicyId": "044f78848ab25cbe7a84c0c6768d7fb98d7a99cad21e6f8298354923",
        "offerAssetName": "47616d654368616e676572546f6b656ef09f9a80",
        "askPolicyId": "",
        "askAssetName": "",
        "priceNumerator": "1000000",
        "priceDenominator": "1",
        "offerQuantity": "3"
    },
    "run": {
        "dependencies": {
            "type": "script",
            "args": "{get('args')}",
            "run": {
                "beaconPolicy": {
                    "type": "plutusScript",
                    "script": {
                        "scriptHex": "",
                        "lang": "plutus_v2"
                    }
                },
                "stakingKey": {
                    "type": "getStakingPublicKey"
                },
                "beaconRedeemer": {
                    "type": "plutusData",
                    "data": {
                        "fromJSON": {
                            "schema": 1,
                            "obj": {
                                "constructor": 1,
                                "fields": []
                            }
                        }
                    }
                },
                "pairBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray(get('args.offerPolicyId')), hexToByteArray(get('args.offerAssetName')), hexToByteArray('00'), hexToByteArray(get('args.askAssetName'))))}"
                },
                "offerBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray('01'), hexToByteArray(get('args.offerPolicyId')), hexToByteArray(get('args.offerAssetName'))))}"
                },
                "askBeacon": {
                    "type": "macro",
                    "run": "{sha256(flatten(hexToByteArray('02'), hexToByteArray(get('args.askPolicyId')), hexToByteArray(get('args.askAssetName'))))}"
                },
                "swapDatum": {
                    "type": "plutusData",
                    "data": {
                        "fromJSON": {
                            "schema": 1,
                            "obj": {
                                "constructor": 0,
                                "fields": [
                                    {"bytes": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209"},
                                    {"bytes": "{get('cache.dependencies.pairBeacon')}"},
                                    {"bytes": "{get('args.offerPolicyId')}"},
                                    {"bytes": "{get('args.offerAssetName')}"},
                                    {"bytes": "{get('cache.dependencies.offerBeacon')}"},
                                    {"bytes": "{get('args.askPolicyId')}"},
                                    {"bytes": "{get('args.askAssetName')}"},
                                    {"bytes": "{get('cache.dependencies.askBeacon')}"},
                                    {"constructor": 0, "fields": [
                                        {"int": "{jsonToObj(get('args.priceNumerator'))}"},
                                        {"int": "{jsonToObj(get('args.priceDenominator'))}"}
                                    ]},
                                    {"constructor": 1, "fields": []},
                                    {"constructor": 1, "fields": []}
                                ]
                            }
                        }
                    }
                },
                "dappAddress": {
                    "type": "buildAddress",
                    "name": "DAppAddress",
                    "addr": {
                        "spendScriptHashHex": "1d6cff26bcab91d2061aad0bd259cbb7d76d25ced2eeaed5926a42ad",
                        "stakePubKeyHashHex": "{get('cache.dependencies.stakingKey.pubKeyHashHex')}"
                    }
                }
            }
        },
        "build": {
            "type": "buildTx",
            "name": "built-open-swap",
            "tx": {
                "mints": [
                    {
                        "policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209",
                        "idPattern": "beaconMint",
                        "assets": [
                            {"assetNameHex": "{get('cache.dependencies.pairBeacon')}", "quantity": "1"},
                            {"assetNameHex": "{get('cache.dependencies.offerBeacon')}", "quantity": "1"},
                            {"assetNameHex": "{get('cache.dependencies.askBeacon')}", "quantity": "1"}
                        ]
                    }
                ],
                "outputs": [
                    {
                        "address": "{get('cache.dependencies.dappAddress')}",
                        "datum": {"datumHex": "{get('cache.dependencies.swapDatum.dataHex')}"},
                        "assets": [
                            {"policyId": "{get('args.offerPolicyId')}", "assetNameHex": "{get('args.offerAssetName')}", "quantity": "{get('args.offerQuantity')}"},
                            {"policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209", "assetNameHex": "{get('cache.dependencies.pairBeacon')}", "quantity": "1"},
                            {"policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209", "assetNameHex": "{get('cache.dependencies.offerBeacon')}", "quantity": "1"},
                            {"policyId": "c4d7d117d9ebcde6db28db40837ff2b1401e9eaaa6eecea9e070e209", "assetNameHex": "{get('cache.dependencies.askBeacon')}", "quantity": "1"}
                        ]
                    }
                ],
                "witnesses": {
                    "plutus": {
                        "scripts": [
                            {
                                "scriptHex": "{get('cache.dependencies.beaconPolicy.scriptHex')}",
                                "lang": "{get('cache.dependencies.beaconPolicy.lang')}"
                            }
                        ],
                        "consumers": [
                            {
                                "scriptHashHex": "{get('cache.dependencies.beaconPolicy.scriptHashHex')}",
                                "redeemer": {
                                    "dataHex": "{get('cache.dependencies.beaconRedeemer.dataHex')}",
                                    "type": "mint",
                                    "itemIdPattern": "beaconMint"
                                }
                            }
                        ]
                    }
                },
                "options": {
                    "collateralCoinSelection": "LASLAD"
                }
            }
        },
        "sign": {
            "type": "signTxs",
            "namePattern": "signed-open-swap",
            "detailedPermissions": false,
            "txs": [
                "{get('cache.build.txHex')}"
            ]
        },
        "submit": {
            "type": "submitTxs",
            "namePattern": "submitted-open-swap",
            "txs": "{get('cache.sign')}"
        }
    }
}
